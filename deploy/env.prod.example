# Copy this content into the GitHub secret PROD_ENV_FILE.
# Do not commit a real production .env file.

GHCR_OWNER=notzairdev
IMAGE_TAG=latest

DNS_DOMAIN=example.com
ACME_EMAIL=admin@example.com
CF_API_TOKEN=cloudflare_token_with_zone_dns_edit
CERTBOT_PROPAGATION_SECONDS=60

AGH_USER=admin
AGH_PASS=replace_with_plain_password_for_api_sync
AGH_PASS_HASH='$2a$10$replace_with_bcrypt_hash'
AGH_INTERNAL_URL=http://adguardhome:3000
AGH_TLS_CERT_PATH=/opt/adguardhome/certs/live/dns.example.com/fullchain.pem
AGH_TLS_KEY_PATH=/opt/adguardhome/certs/live/dns.example.com/privkey.pem

API_SECRET=replace_with_long_random_bearer_token
PLAIN_DNS_IP=replace_with_vm_public_ip
LOG_LEVEL=info

DASHBOARD_USER=admin
DASHBOARD_PASS_HASH='$2a$14$replace_with_caddy_hash_password_output'
