# Domain and public routing
DNS_DOMAIN=example.com
ACME_EMAIL=admin@example.com
CF_API_TOKEN=cloudflare_token_with_zone_dns_edit

# Local port overrides for development. Production compose binds standard ports.
DNS_PORT=5353
DNS_TCP_PORT=5353
AGH_HTTP_PORT=3000
DOT_PORT=853
DOQ_PORT=784
HTTP_PORT=8080
HTTPS_PORT=8443

# AdGuardHome admin/API credentials.
# AGH_PASS_HASH is the bcrypt hash stored in AdGuardHome.yaml.
AGH_USER=admin
AGH_PASS=change_me
AGH_PASS_HASH='$2a$10$replace_with_bcrypt_hash'
AGH_INTERNAL_URL=http://adguardhome:3000

# Profile API
API_SECRET=replace_with_long_random_bearer_token
API_PORT=4000
DB_PATH=/app/data/profiles.db
PLAIN_DNS_IP=
LOG_LEVEL=info
NODE_ENV=development

# Caddy basic auth for the upstream AdGuardHome dashboard at /agh.
DASHBOARD_USER=admin
DASHBOARD_PASS_HASH='$2a$14$replace_with_caddy_hash_password_output'

# TLS files used by AdGuardHome for DoT/DoQ.
# Phase 0 expects these files to exist in runtime/certs before enabling public DoT.
AGH_TLS_CERT_PATH=/opt/adguardhome/certs/fullchain.pem
AGH_TLS_KEY_PATH=/opt/adguardhome/certs/privkey.pem
