{
	email {$ACME_EMAIL}
}

*.dns.{$DNS_DOMAIN}, dns.{$DNS_DOMAIN} {
	tls {
		dns cloudflare {$CF_API_TOKEN}
	}

	reverse_proxy adguardhome:3000 {
		header_up Host {host}
	}
}

{$DNS_DOMAIN} {
	tls {
		dns cloudflare {$CF_API_TOKEN}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
	}

	handle /health {
		reverse_proxy api:4000
	}

	handle /apk/* {
		reverse_proxy api:4000
	}

	handle /api/* {
		reverse_proxy api:4000
	}

	handle /agh/* {
		basic_auth {
			{$DASHBOARD_USER} {$DASHBOARD_PASS_HASH}
		}
		uri strip_prefix /agh
		reverse_proxy adguardhome:3000
	}

	handle {
		root * /srv/dashboard
		try_files {path} /index.html
		file_server
	}
}
